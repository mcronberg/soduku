{
    "name": "sudoku",
    "version": "1.0.2",
    "description": "A free, client-side Sudoku game that runs entirely in the browser — no server, no account, no install required.",
    "type": "module",
    "scripts": {
        "test": "node --test tests/generator.test.js",
        "test:e2e": "npx playwright test --project=chromium --ignore-snapshots",
        "test:e2e:all": "npx playwright test --ignore-snapshots",
        "test:e2e:ui": "npx playwright test --ui",
        "test:e2e:headed": "npx playwright test --headed --project=chromium",
        "test:visual": "npx playwright test tests/e2e/visual.spec.js --project=chromium",
        "test:visual:update": "npx playwright test tests/e2e/visual.spec.js --update-snapshots --project=chromium",
        "test:all": "npm run test && npm run test:e2e"
    },
    "keywords": [
        "sudoku",
        "game",
        "puzzle"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "serve": "^14.2.6"
    }
}